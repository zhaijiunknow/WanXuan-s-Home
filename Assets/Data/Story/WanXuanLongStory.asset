  - stepId: 1-1-text-0017
    stepType: 1
    dialogue:
      speakerName: 
      content: "\u86CB\u7CD5\u80DA\u5F88\u7EC6\uFF0C\u54AC\u65AD\u65F6\u51E0\u4E4E\u6CA1\u6709\u58F0\u97F3\uFF0C\u53EA\u7559\u4E0B\u4E00\u79CD\u88AB\u6E7F\u6DA6\u5976\u6CB9\u6D78\u900F\u540E\u7684\u7EF5\u5BC6\u611F\u3002"

  - stepId: 1-1-text-0007
    stepType: 1
    dialogue:
      speakerName: 
      content: "\u91CC\u9762\u662F\u6211\u524D\u51E0\u5929\u9884\u7EA6\u7684\u9650\u91CF\u8349\u8393\u86CB\u7CD5\u3002"

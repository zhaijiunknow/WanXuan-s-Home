  - stepId: 1-1-text-0028
    stepType: 1
    dialogue:
      speakerName: 
      content: "\u6709\u65F6\u5019\u6211\u4F1A\u6000\u7591\uFF0C\u81EA\u5DF1\u662F\u4E0D\u662F\u5DF2\u7ECF\u628A\u751F\u6D3B\u8FC7\u6210\u4E86\u4E00\u4E2A\u5BC6\u5C01\u5F97\u592A\u597D\u7684\u50A8\u7269\u76D2\u3002"

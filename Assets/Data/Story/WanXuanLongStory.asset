    endingMessage: 
    choices: []
    markerTitle: 
    stageNote: 
  - stepId: 1-1-text-0006
    stepType: 1
    dialogue:
      speakerName: 
      content: "\u6211\u5750\u5728\u5BA2\u5385\u4E2D\u592E\u7684\u6C99\u53D1\u4E0A\uFF0C\u62C6\u5F00\u4E00\u53EA\u7EB8\u76D2\u3002"

    stepType: 1
    dialogue:
      speakerName: 
      content: "\u5976\u6CB9\u5148\u5316\u5F00\uFF0C\u50CF\u4E91\u4E00\u6837\u6ED1\u8FC7\u820C\u5C16\uFF0C\u751C\u5473\u5E76\u4E0D\u731B\u70C8\uFF0C\u800C\u662F\u67D4\u548C\u5730\u94FA\u5F00\uFF0C\u540E\u9762\u624D\u8DDF\u4E0A\u8349\u8393\u7684\u9178\u3002"

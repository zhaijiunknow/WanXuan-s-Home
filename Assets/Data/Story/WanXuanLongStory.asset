    markerTitle: 
    stageNote: "\u3010\u573A\u666F\u3011\u5BA2\u5385 / \u5348\u540E / \u6674\n\u3010BG\u3011\u5927\u5BA2\u5385\uFF0C\u5927\u7247\u843D\u5730\u7A97\uFF0C\u5149\u7EBF\u5B89\u9759\u5730\u843D\u5728\u5730\u677F\u4E0A\n\u3010BGM\u3011\u8F7B\u67D4\u94A2\u7434\uFF0C\u6781\u6DE1"
  - stepId: 1-1-text-0003

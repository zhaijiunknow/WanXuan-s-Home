  - stepId: 1-1-text-0009
    stepType: 1
    dialogue:
      speakerName: 
      content: "\u6211\u628A\u5851\u6599\u53C9\u63D2\u8FDB\u5976\u6CB9\u65F6\uFF0C\u6700\u5148\u611F\u53D7\u5230\u7684\u662F\u963B\u529B\u3002"

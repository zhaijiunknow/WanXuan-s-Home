  - stepId: 1-1-text-0008
    stepType: 1
    dialogue:
      speakerName: 
      content: "\u57CE\u91CC\u5F88\u96BE\u8BA2\uFF0C\u4EF7\u683C\u4E5F\u5938\u5F20\u3002\u5E97\u5BB6\u7528\u900F\u660E\u7684\u8584\u819C\u7F69\u7740\uFF0C\u50CF\u5728\u4FDD\u62A4\u4E00\u4EF6\u6BD4\u751C\u70B9\u66F4\u63A5\u8FD1\u5C55\u54C1\u7684\u4E1C\u897F\u3002"

  - stepId: 1-1-text-0011
    stepType: 1
    dialogue:
      speakerName: 
      content: "\u5B83\u50CF\u521D\u96EA\u4E00\u6837\u677E\u8F6F\uFF0C\u53C9\u5C16\u9677\u8FDB\u53BB\u65F6\u4F1A\u5FAE\u5FAE\u56DE\u5F39\uFF0C\u7559\u4E0B\u4E00\u9053\u7EC6\u7A84\u7684\u88C2\u53E3\u3002"

    stepType: 1
    dialogue:
      speakerName: 
      content: "\u4F46\u90A3\u4E9B\u58F0\u97F3\u90FD\u592A\u89C4\u5F8B\u4E86\uFF0C\u89C4\u5F8B\u5F97\u50CF\u4E00\u79CD\u88AB\u5141\u8BB8\u5B58\u5728\u7684\u80CC\u666F\u3002\u5B83\u4EEC\u4E0D\u6253\u6270\u4EBA\uFF0C\u4E5F\u4E0D\u966A\u4F34\u4EBA\u3002"

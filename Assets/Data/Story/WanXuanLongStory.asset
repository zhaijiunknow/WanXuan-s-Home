  - stepId: 1-1-text-0012
    stepType: 1
    dialogue:
      speakerName: 
      content: "\u8868\u9762\u7684\u8349\u8393\u5207\u5F97\u5F88\u6F02\u4EAE\uFF0C\u8FB9\u7F18\u8FD8\u6302\u7740\u7EC6\u5C0F\u7684\u6C41\u6C34\uFF0C\u7EA2\u5F97\u6E05\u900F\uFF0C\u50CF\u5348\u540E\u73BB\u7483\u4E0A\u77ED\u6682\u505C\u4F4F\u7684\u4E00\u70B9\u5915\u5149\u3002"

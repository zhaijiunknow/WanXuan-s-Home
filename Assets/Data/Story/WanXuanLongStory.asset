  - stepId: 1-1-text-0016
    stepType: 1
    dialogue:
      speakerName: 
      content: "\u90A3\u4E00\u70B9\u9178\u8BA9\u751C\u5473\u6709\u4E86\u5C42\u6B21\uFF0C\u4E0D\u81F3\u4E8E\u817B\uFF0C\u4E5F\u4E0D\u81F3\u4E8E\u5BE1\u6DE1\u3002"
